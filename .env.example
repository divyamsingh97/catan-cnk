# Copy this file to ".env.local" and fill in the values from your Firebase
# project's web app config (Firebase console -> Project settings -> Your apps).
#
# NOTE: These Firebase web values are not secrets — they are shipped to every
# browser by design. Access is controlled by Firebase Security Rules + the
# allowed-domains list in Firebase Auth, NOT by hiding these strings.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated list of Google emails allowed to use the app (your friends).
# Leave empty to allow anyone who signs in. This is a convenience gate only;
# real enforcement also lives in Firestore Security Rules.
VITE_ALLOWLIST=
